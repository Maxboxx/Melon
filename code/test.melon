
include Melon.Console.log
include Melon.File
import Papaya

--/
import Kiwi

Block: block = Block {
	insts = {
		.assign {
			v = .name("x"),
			e = .value(Value.num(3))
		},
		
		.assign {
			v = .name("y"),
			
			e = .add(
				Value.var(Var.name("x")),
				Value.num(4)
			)
		},
		
		.return
	}
}

log(block.toKiwi())
/--

PapayaBuilder: builder = PapayaBuilder()

builder.emit(Op.int32, 1, 3)
builder.emit(Op.int32, 2, 5)
builder.emit(Op.add32, 1, 2, 3)
builder.sys(SysOp.print, 3)

File.writeBytes("code/output/out.papaya", builder.bytes)
